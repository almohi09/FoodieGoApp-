{
  "name": "FoodieGoApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint App.tsx src __tests__ e2e --ext .js,.ts,.tsx",
    "start": "react-native start",
    "start:wifi": "react-native start --host 0.0.0.0",
    "test": "jest",
    "test:e2e:smoke": "jest --config e2e/jest.e2e.config.js --runInBand --watchAll=false --forceExit",
    "build:e2e:detox:android": "npx detox build -c android.emu.debug",
    "test:e2e:detox": "npx detox test -c android.emu.debug --cleanup",
    "build:android": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@supabase/supabase-js": "^2.102.1",
    "axios": "^1.8.4",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^2.24.0",
    "react-native-maps": "^1.27.2",
    "react-native-razorpay": "^2.3.1",
    "react-native-responsive-screen": "^1.4.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.11.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
